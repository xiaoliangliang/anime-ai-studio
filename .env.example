# API 代理服务器配置
PORT=3001

# Pollinations API Key (从 https://enter.pollinations.ai 获取)
# 用于编剧/分镜/设计阶段的文本生成
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Pollinations Publishable Key (前端直连用，pk_ 开头的 key 可以安全暴露在前端)
# 从 https://enter.pollinations.ai 获取 Publishable Key
VITE_POLLINATIONS_API_KEY=your_pollinations_publishable_key_here

# RunComfy API Token (从 https://www.runcomfy.com/profile?section=api-tokens 获取)
# 用于 Seedream 4.5 文生图/图生图
RUNCOMFY_API_TOKEN=your_runcomfy_api_token_here

# imgbb API Key (从 https://api.imgbb.com/ 获取)
IMGBB_API_KEY=your_imgbb_api_key_here

# 前端配置 (Vite)
VITE_API_BASE_URL=http://localhost:3001

# 功能开关（接入支付前默认关闭图片/视频生成）
# 设置为 true 才会开启
VITE_ENABLE_IMAGE_GENERATION=false
VITE_ENABLE_VIDEO_GENERATION=false

# 图片生成供应商配置
# 可选值: pollinations | runcomfy
# pollinations: 同步模式，快速响应，支持多种模型
# runcomfy: 异步模式，高质量 Seedream 4.5
VITE_IMAGE_PROVIDER=pollinations

# 视频生成供应商配置（用户侧/导演阶段，多供应商切换）
# 可选值: runcomfy | pollinations
# runcomfy: 默认，走后端代理 /api/runcomfy/*（服务端使用 RUNCOMFY_API_TOKEN）
# pollinations: 前端直连 gen.pollinations.ai（必须配置 VITE_POLLINATIONS_API_KEY，pk_ 开头；限流更严格）
# 兼容性说明：pollinations 仅支持 16:9/9:16 且 2-10 秒；其他画幅/更长时长将自动兜底/映射（见 spec 文档）
VITE_VIDEO_PROVIDER=runcomfy
