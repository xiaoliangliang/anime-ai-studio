# API 代理服务器配置
PORT=3001

# Pollinations API Key (从 https://enter.pollinations.ai 获取)
# 用于编剧/分镜/设计阶段的文本生成
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# RunComfy API Token (从 https://www.runcomfy.com/profile?section=api-tokens 获取)
# 用于 Seedream 4.5 文生图/图生图
RUNCOMFY_API_TOKEN=your_runcomfy_api_token_here

# imgbb API Key (从 https://api.imgbb.com/ 获取)
IMGBB_API_KEY=your_imgbb_api_key_here

# 前端配置 (Vite)
VITE_API_BASE_URL=http://localhost:3001

# 功能开关（接入支付前默认关闭图片/视频生成）
# 设置为 true 才会开启
VITE_ENABLE_IMAGE_GENERATION=false
VITE_ENABLE_VIDEO_GENERATION=false
