# ==========================================
# Runtime
# ==========================================
PORT=3001

# ==========================================
# Server-side secrets (NEVER expose to frontend)
# ==========================================
# Pollinations server key (secret key, e.g. plln_sk_*)
# Apply: https://enter.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_server_key_here

# RunComfy API token
# Apply: https://www.runcomfy.com/profile?section=api-tokens
RUNCOMFY_API_TOKEN=your_runcomfy_api_token_here

# imgbb API key
# Apply: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# Optional: restrict API requests by Origin (comma-separated, exact origin)
# Example:
# ALLOWED_ORIGINS=http://localhost:5173,https://animeaistudio.com
ALLOWED_ORIGINS=

# Optional: extend host allowlist for /api/fetch-file (comma-separated suffixes)
FETCH_FILE_ALLOWED_HOST_SUFFIXES=

# Optional: verbose API logs in development only
DEBUG_API_LOGS=false

# ==========================================
# Frontend public env (safe to expose)
# ==========================================
# Pollinations publishable key (pk_*)
VITE_POLLINATIONS_API_KEY=your_pollinations_publishable_key_here

# API base URL:
# - local vite proxy mode: keep empty string
# - vercel dev mode: http://localhost:3000
VITE_API_BASE_URL=

# Feature flags
VITE_ENABLE_IMAGE_GENERATION=false
VITE_ENABLE_VIDEO_GENERATION=false

# Providers
VITE_IMAGE_PROVIDER=pollinations
VITE_VIDEO_PROVIDER=runcomfy
